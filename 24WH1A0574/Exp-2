✅ Registration successful
<br><br>
<button class="btn btn-success btn-sm"
onclick="goLogin()">OK</button>
</div>
</div>
</div>
</div>
<script>
function registerSuccess(e){
e.preventDefault();
document.getElementById("registerMsg").classList.remove("d-none");
}
function goLogin(){
window.location.href = "login.html";
}
</script>
</body>
</html>

//booking.html
<!DOCTYPE html>
<html>
<head>
<title>Book Ticket</title>
<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body id="bookingBody" class="movie-bg">
<div class="container mt-5">
<div class="row justify-content-center">
<div class="col-md-6">
<div class="page-box">
<h3 class="text-center">  Ticket Booking</h3>
<form onsubmit="bookingSuccess(event)">
<select class="form-control mb-2"
onchange="changeBG(this.value)">
<option value="movie">Movie</option>
<option value="bus">Bus</option>
<option value="train">Train</option>
</select>
<input type="date" class="form-control mb-2" required>
<input type="number" class="form-control mb-2"
placeholder="Number of Tickets" required>
<button class="btn btn-warning w-100">Confirm Booking</button>
</form>
</div>
<!-- SUCCESS BOX -->
<div id="bookingMsg" class="msg-box d-none">
  Ticket booked successfully
<br><br>
<button class="btn btn-success btn-sm"
onclick="goHome()">OK</button>
</div>
</div>
</div>
</div>
<script>
function changeBG(type){
document.getElementById("bookingBody").className = type + "-bg";
}
function bookingSuccess(e){
e.preventDefault();
document.getElementById("bookingMsg").classList.remove("d-none");
}
function goHome(){
window.location.href = "home.html";
}
</script>
</body>
</html>
