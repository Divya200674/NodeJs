<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body class="common-bg">
<div class="container mt-5">
<div class="row justify-content-center">
<div class="col-md-4">
<div class="page-box">
<h3 class="text-center">  Login</h3>
<!-- ERROR MESSAGE -->
<div id="errorMsg" class="alert alert-danger d-none"></div>
<form onsubmit="return loginValidate()">
<input type="text" id="username" class="form-control mb-3"
placeholder="Username">
<input type="password" id="password" class="form-control mb-3"
placeholder="Password">
<button class="btn btn-primary w-100">Login</button>
</form>
</div>
<!-- SUCCESS BOX -->
<div id="loginMsg" class="msg-box d-none text-center mt-3">
✅ Logged in successfully
<br><br>
<button class="btn btn-success btn-sm"
onclick="goHome()">OK</button>
</div>
</div>
</div>
</div>
<script>
function loginValidate() {
let username = document.getElementById("username").value.trim();
let password = document.getElementById("password").value.trim();
let errorMsg = document.getElementById("errorMsg");
// Reset messages
errorMsg.classList.add("d-none");
errorMsg.innerHTML = "";
// Username validation
if (username === "") {
errorMsg.innerHTML = "❌ Username cannot be empty";
errorMsg.classList.remove("d-none");
return false;
}
if (username.length < 4) {
errorMsg.innerHTML = "❌ Username must be at least 4 characters";
errorMsg.classList.remove("d-none");
return false;
}
// Password validation
if (password === "") {
errorMsg.innerHTML = "❌ Password cannot be empty";
errorMsg.classList.remove("d-none");
return false;
}
if (password.length < 6) {
errorMsg.innerHTML = "❌ Password must be at least 6 characters";
errorMsg.classList.remove("d-none");
return false;
}
// If all validations pass
document.getElementById("loginMsg").classList.remove("d-none");
return false; // prevent actual form submit
}
function goHome(){
window.location.href = "home.html";
}
</script>
</body>
</html>

