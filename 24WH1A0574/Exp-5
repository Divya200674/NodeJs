<!DOCTYPE html>
<html>
<head>
<title>Book Ticket</title>
<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body id="bookingBody" class="movie-bg">
<div class="container mt-5">
<div class="row justify-content-center">
<div class="col-md-6">
<div class="page-box">
<h3 class="text-center">  Ticket Booking</h3>
<!-- ERROR MESSAGE -->
<div id="errorMsg" class="alert alert-danger d-none"></div>
<form onsubmit="return bookingValidate()">
<select id="type" class="form-control mb-2"
onchange="changeBG(this.value)">
<option value="">-- Select Ticket Type --</option>
<option value="movie">Movie</option>
<option value="bus">Bus</option>
<option value="train">Train</option>
</select>
<input type="date" id="date" class="form-control mb-2">
<input type="number" id="tickets" class="form-control mb-2"
placeholder="Number of Tickets">
<button class="btn btn-warning w-100">Confirm Booking</button>
</form>
</div>
<!-- SUCCESS BOX -->
<div id="bookingMsg" class="msg-box d-none text-center mt-3">
  Ticket booked successfully
<br><br>
<button class="btn btn-success btn-sm"
onclick="goHome()">OK</button>
</div>
</div>
</div>
</div>
<script>
function changeBG(type){
if(type !== ""){
document.getElementById("bookingBody").className = type + "-bg";
}
}
function bookingValidate(){
let type = document.getElementById("type").value;
let date = document.getElementById("date").value;
let tickets = document.getElementById("tickets").value;
let errorMsg = document.getElementById("errorMsg");
errorMsg.classList.add("d-none");
errorMsg.innerHTML = "";
// Type validation
if(type === ""){
errorMsg.innerHTML = "❌ Please select ticket type";
errorMsg.classList.remove("d-none");
return false;
}
// Date validation
if(date === ""){
errorMsg.innerHTML = "❌ Please select a date";
errorMsg.classList.remove("d-none");
return false;
}
let selectedDate = new Date(date);
let today = new Date();
today.setHours(0,0,0,0);
if(selectedDate < today){
errorMsg.innerHTML = "❌ Date cannot be in the past";
errorMsg.classList.remove("d-none");
return false;
}
// Ticket count validation
if(tickets === "" || tickets <= 0){
errorMsg.innerHTML = "❌ Enter valid number of tickets";
errorMsg.classList.remove("d-none");
return false;
}
if(tickets > 10){
errorMsg.innerHTML = "❌ Maximum 10 tickets allowed";
errorMsg.classList.remove("d-none");
return false;
}
// Success
document.getElementById("bookingMsg").classList.remove("d-none");
return false; // prevent actual submit
}
function goHome(){
window.location.href = "home.html";
}
</script>
</body>
</html>
