<!DOCTYPE html>
<html>
<head>
<title>Register</title>
<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body class="common-bg">
<div class="container mt-5">
<div class="row justify-content-center">
<div class="col-md-5">
<div class="page-box">
<h3 class="text-center">  Registration</h3>
<!-- ERROR MESSAGE -->
<div id="errorMsg" class="alert alert-danger d-none"></div>
<form onsubmit="return registerValidate()">
<input type="text" id="name" class="form-control mb-2"
placeholder="Name">
<input type="email" id="email" class="form-control mb-2"
placeholder="Email">
<input type="password" id="password" class="form-control mb-2"
placeholder="Password">
<button class="btn btn-success w-100">Register</button>
</form>
</div>
<!-- SUCCESS BOX -->
<div id="registerMsg" class="msg-box d-none text-center mt-3">
✅ Registration successful
<br><br>
<button class="btn btn-success btn-sm"
onclick="goLogin()">OK</button>
</div>
</div>
</div>
</div>
<script>
function registerValidate() {
let name = document.getElementById("name").value.trim();
let email = document.getElementById("email").value.trim();
let password = document.getElementById("password").value.trim();
let errorMsg = document.getElementById("errorMsg");
// reset error
errorMsg.classList.add("d-none");
errorMsg.innerHTML = "";
// Name validation
if (name === "") {
errorMsg.innerHTML = "❌ Name cannot be empty";
errorMsg.classList.remove("d-none");
return false;
}
if (name.length < 3) {
errorMsg.innerHTML = "❌ Name must be at least 3 characters";
errorMsg.classList.remove("d-none");
return false;
}
// Email validation
let emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
if (email === "") {
errorMsg.innerHTML = "❌ Email cannot be empty";
errorMsg.classList.remove("d-none");
return false;
}
if (!emailPattern.test(email)) {
errorMsg.innerHTML = "❌ Enter a valid email address";
errorMsg.classList.remove("d-none");
return false;
}
// Password validation
if (password === "") {
errorMsg.innerHTML = "❌ Password cannot be empty";
errorMsg.classList.remove("d-none");
return false;
}
if (password.length < 6) {
errorMsg.innerHTML = "❌ Password must be at least 6 characters";
errorMsg.classList.remove("d-none");
return false;
}
// Success
document.getElementById("registerMsg").classList.remove("d-none");
return false; // prevent actual submit
}
function goLogin(){
window.location.href = "login.html";
}
</script>
</body>
</html>

